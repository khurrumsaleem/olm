{% extends "lumped0d-base.jt.inp" %}
{% block fuelcomp %}
fuelcomp{
    stdcomp(fuel){ base=uo2
        iso[ 92234={{comp.system.uo2.iso.u234}} 92235={{comp.system.uo2.iso.u235}} 92236={{comp.system.uo2.iso.u236}} 92238={{comp.system.uo2.iso.u238}} ]
    }
    mix(1){ comps[
        fuel={{lumped0d.uo2_wtpt}}
        Gd2O3={{lumped0d.gd2o3_wtpt}}
    ] }
}
{% endblock %}
